# Copy this to .env.local for local development
# Use local Supabase instance (run: supabase start)

# Note: VITE_* variables are public and baked into the JavaScript bundle at build time
# VITE_SUPABASE_PUBLISHABLE_KEY is intentionally public (Supabase anon key)

VITE_ENVIRONMENT=development
VITE_SUPABASE_PROJECT_ID=local
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN3bUJGIiwicm9sZSI6ImFub24iLCJpYXQiOjE2NDc5MjMyMDAsImV4cCI6MTk2MzQ5OTIwMH0.MOCK_KEY_FOR_LOCAL_DEV
VITE_API_URL=http://localhost:8000
VITE_QUIZ_API_URL=http://localhost:8000
