# Scheduler (Observation Scheduler) feature scope
# NOTE: In this codebase a "visit" is a row in the cot_observations table.
# Statuses are: Scheduled | Draft | Submitted | Approved (there is no "Completed" status —
# the "Completed" tab shows Submitted + Approved). Neo AI scoring runs in the debrief flow,
# decoupled from marking a visit done. RLS is per-observer (not per-region).

# ── Page / container: region detection + tab routing ─────────────────────────
src/pages/ObservationScheduler.tsx

# ── Smart Plan: teacher prioritization UI (one tab per region) ───────────────
src/components/observation/SmartScheduleTab.tsx
src/components/observation/PunjabSmartScheduleTab.tsx
src/components/observation/PindiSmartScheduleTab.tsx
src/components/observation/DCDashboard.tsx
src/components/observation/PriorityList.tsx
src/components/observation/FourWeekOverview.tsx
src/components/observation/WeeklyPlanView.tsx

# ── Prioritization / ranking / weekly-plan business logic ────────────────────
src/lib/scheduler-utils.ts
src/domain/thresholds.ts

# ── Schedule form: field validation + Schedule Visit button gating ───────────
src/components/observation/ScheduleVisitModal.tsx

# ── Visits dashboard: Scheduled/Draft/Completed tabs, state transitions, delete
src/components/observation/VisitsDashboardTab.tsx
src/components/observation/ObservationsOverviewTab.tsx
src/components/observation/TeacherAbsentModal.tsx

# ── Neo AI debrief: audio capture, processing, scoring feedback ──────────────
src/components/observation/DebriefForm.tsx
src/components/observation/QuickObservationPanel.tsx
src/components/observation/NeoAnalysis.tsx
src/lib/audioQueue.ts

# ── Data access layer (frontend → FastAPI) ───────────────────────────────────
src/data/observations.ts
src/data/punjabTeachers.ts
src/data/rawalpindiTeachers.ts

