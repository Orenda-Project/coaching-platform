src/hooks/useCoaching.ts
src/hooks/usePunjabCoaching.ts
src/hooks/useRawalpindiCoaching.ts
src/hooks/useObservation.ts

# ── Offline support: queue visits, sync on reconnect (Punjab / Rawalpindi) ───
src/lib/punjabOfflineQueue.ts
src/lib/rawalpindiOfflineQueue.ts

# ── Types ─────────────────────────────────────────────────────────────────────
src/types/observation.ts
src/types/teacher.ts

